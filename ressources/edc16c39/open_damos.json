  "$schema": "../open_damos.schema.json",
  "ecu": "edc16c39",
  "name": "open_damos — EDC16C39 Bosch (CNH / New Holland / Case IH / Steyr)",
  "version": "0.1.0",
  "license": "CC0-1.0",
  "homepage": "https://github.com/Poisson48/open_car_reprog/wiki/Open-DAMOS",
  "description": "Open DAMOS for Bosch EDC16C39 (Iveco/FPT F4DE/F4DF, New Holland T6/T7, Case IH Maxxum/Puma, Steyr Profi tractors). Generated from the manufacturer DAMOS (ASAP2 A2L) + matching ROM via the DAMOS->OpenDAMOS convention: addresses + conversions from the A2L, axis fingerprints read from the reference ROM. Each entry relocates by fingerprint onto any firmware variant of the family (30+ power ratings share the same calibration structure). Big-endian.",
  "byteOrder": "BE",
  "baseline": {
    "source": "New Holland T6090 140KW F4DE9687VJ101 / 8480.hex",
    "damos": "8480.a2l (DAMOS++ V1.20, PROJECT C400 'EDC16C39 for CNH')",
    "note": "Addresses + COMPU_METHOD conversions taken from 8480.a2l; fingerprints read from 8480.hex at those addresses. Fingerprint relocation finds the same maps in the other 30 variant ROMs."
  },
