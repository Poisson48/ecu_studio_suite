  "baseline": {
    "source": "X_7HH21-000027D9.HEX (TriCore image @0x80000000)",
    "damos": "X_7HH21-000027D9.A2L (ASAP2 1.4, MSB_LAST)",
    "note": "Addresses stored as offset within the flash image (A2L addr - 0x80000000). Fingerprints read from the reference ROM; relocation verified onto sibling firmware C56 (7HH50)."
